{
  "name": "paperwork-switzerland",
  "version": "1.0.0",
  "description": "AI agent skills + tools for Swiss bureaucracy (26 cantons)",
  "private": true,
  "scripts": {
    "calc": "node scripts/calc.js",
    "test": "node --test scripts/tests/",
    "test:calc": "node scripts/test-deterministic-calculations.js",
    "lint": "eslint scripts/ integrations/ || true",
    "qrbill": "node scripts/generate-qr-bill.js",
    "fetch": "node integrations/bexio/fetch.js; node integrations/stripe/fetch.js",
    "fetch:bexio": "node integrations/bexio/fetch.js",
    "fetch:stripe": "node integrations/stripe/fetch.js",
    "parse:camt": "node integrations/postfinance/parse.js",
    "validate-iban": "node scripts/validate-iban.js",
    "validate-uid": "node scripts/validate-uid.js",
    "validate-qr": "node scripts/validate-qr-reference.js",
