# bexio (Swiss SME accounting)
# Dashboard > Account > API tokens
BEXIO_API_TOKEN=your-bexio-token

# Stripe (online payments — CHF / EUR / USD)
# Dashboard > Developers > API keys
STRIPE_SECRET=sk_live_...

# Multiple Stripe accounts (one var per account, configured in company.json)
# STRIPE_SECRET_SHOP=sk_live_...

# Stripe Connect (platform key for sub-accounts)
# STRIPE_PLATFORM_SECRET=sk_live_...
# acct_xxx values go in company.json under stripe_accounts[].stripe_account_id

# --- Eval runner (evals/run_evals.py --mode=live) ---
# Anthropic — used by --provider=anthropic (model: claude-haiku-4-5)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / Codex — used by --provider=openai (model: gpt-4o-mini)
# OPENAI_API_KEY=sk-...

# Mistral — used by --provider=mistral (model: mistral-small-latest)
# Get one at https://console.mistral.ai/
# MISTRAL_API_KEY=...
