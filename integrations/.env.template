# integrations/.env.template
#
# Copy to `.env` at the repo root (or export in your shell) and fill in.
# Do NOT commit your filled-in .env — it is gitignored.
#
# Each connector reads its own env vars at runtime. Missing vars produce a
# clear error message pointing back here.

# --- bexio (Swiss SME accounting / invoicing) ---
# Dashboard → Account → API tokens
# Used by: integrations/bexio/fetch.js
BEXIO_API_KEY=
# Legacy / actual var name expected by the connector code:
BEXIO_API_TOKEN=

# --- Stripe ---
# Dashboard → Developers → API keys (use the live or restricted key)
# Used by: integrations/stripe/fetch.js
# The connector resolves `process.env[account.env_key]` per company.json account;
# common names below — only set the ones you actually use.
STRIPE_API_KEY=
STRIPE_SECRET=
STRIPE_PLATFORM_SECRET=

# --- PostFinance (camt.053 retrieval — when using the API, not parse-only) ---
# Required for any future API-based pull. parse.js itself is offline.
# Issued by PostFinance when you enrol for ISO 20022 multibanking / EBICS.
POSTFINANCE_PARTNER_ID=
